{
  "name": "vkarmani-desktop",
  "private": true,
  "version": "0.13.30",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/typescript/bin/tsc -p tsconfig.json --noEmit && node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "tauri:dev": "npx tauri dev",
    "tauri:build": "npx tauri build",
    "tauri": "npx tauri",
    "verify:updater": "node scripts/verify-updater-config.mjs",
    "test:parsers": "node ./node_modules/vitest/vitest.mjs run tests/remnawave.test.ts --pool=threads --poolOptions.threads.singleThread=true",
    "release:version": "node scripts/set-version.mjs",
    "prepare:xray:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/fetch-xray-windows.ps1 -Force"
  },
  "dependencies": {
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-updater": "2.10.0",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "4.3.4",
    "typescript": "^6.0.3",
    "vite": "^5.4.21",
    "vitest": "2.1.9"
  }
}
