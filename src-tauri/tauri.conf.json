{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VKarmani",
  "version": "0.13.30",
  "identifier": "com.vkarmani.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VKarmani Desktop",
        "width": 1288,
        "height": 736,
        "minWidth": 1120,
        "minHeight": 660,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "maximizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data: https:; connect-src 'self' https: http://127.0.0.1:*; font-src 'self' data:; object-src 'none'; base-uri 'none'; frame-ancestors 'none'",
      "capabilities": [
        "main-capability"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../resources/core/windows/xray.exe": "core/windows/xray.exe",
      "../resources/core/windows/geoip.dat": "core/windows/geoip.dat",
      "../resources/core/windows/geosite.dat": "core/windows/geosite.dat",
      "../resources/core/windows/wintun.dll": "core/windows/wintun.dll",
      "../resources/core/windows/core-manifest.json": "core/windows/core-manifest.json",
      "../public/assets/logo-dark.jpg": "assets/logo-dark.jpg",
      "../public/assets/logo-white.jpg": "assets/logo-white.jpg",
      "../public/assets/wallpaper.jpg": "assets/wallpaper.jpg",
      "../public/assets/logo-vkarmani.png": "assets/logo-vkarmani.png"
    },
    "createUpdaterArtifacts": true,
    "publisher": "VKarmani",
    "shortDescription": "Безопасный VPN-клиент для ПК с поддержкой Xray, Proxy и TUN.",
    "longDescription": "VKarmani — безопасный desktop VPN-клиент для Windows с поддержкой Remnawave, Xray, Proxy и TUN, диагностикой подключения, системным tray и автообновлениями.",
    "category": "Utility",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "languages": [
          "Russian",
          "English"
        ],
        "displayLanguageSelector": true,
        "installMode": "currentUser",
        "startMenuFolder": null,
        "installerHooks": "nsis/installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "windows": {
        "installMode": "passive"
      },
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE1RDk3MjRBQUFGOTY3RUEKUldUcVovbXFTbkxaRlpxMHlGck1Wai9wZFJxK1JXemZJOU1yZkpScW5aUmNSdHpnWVlPS1ZJZzUK",
      "endpoints": [
        "https://github.com/SUXARIK-GITHUB/VKarmani-Desktop/releases/latest/download/latest.json"
      ]
    }
  }
}
